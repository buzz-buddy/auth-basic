# syntax=docker/dockerfile:1
# Development image: full dependencies + Nest hot reload.
# Built by docker-compose.dev.yml. Source is bind-mounted at runtime,
# so this image mainly provides Node, deps, and the generated Prisma client.

FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json prisma.config.ts ./
COPY prisma ./prisma

RUN npm ci

COPY . .

RUN npx prisma generate

EXPOSE 3000

CMD ["npm", "run", "start:dev"]
