# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_basic?schema=public"

# Docker Compose: copy .env.docker.example to .env
#   Dev:  docker compose -f docker-compose.dev.yml up --build
#   Prod: docker compose -f docker-compose.prod.yml up -d  (requires DOCKER_IMAGE in .env)

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_ACCESS_EXPIRES_IN="15m"

# Frontend origin(s) for CORS (comma-separated). Required for httpOnly refresh cookie.
# Customer app + admin dashboard (add admin origin when that app runs locally):
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
REFRESH_TOKEN_COOKIE_NAME="refreshToken"
# COOKIE_SECURE="true"
# COOKIE_SAME_SITE="lax"

# Email verification token lifetime (e.g. 24h, 48h)
EMAIL_VERIFICATION_EXPIRES_IN="24h"

# Frontend URL where users verify email (token appended as ?token=)
APP_VERIFY_EMAIL_URL="http://localhost:3000/verify-email"

# Password reset token lifetime (e.g. 1h, 30m)
PASSWORD_RESET_EXPIRES_IN="1h"

# Frontend URL where users land to set a new password (token appended as ?token=)
APP_RESET_PASSWORD_URL="http://localhost:3000/reset-password"

# AWS (shared by SES and S3)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
SES_FROM_EMAIL="noreply@yourdomain.com"

# S3 profile pictures (private bucket — API returns presigned read URLs)
AWS_S3_BUCKET="your-bucket-name"
AWS_S3_AVATAR_PREFIX="avatars"
# Shared public assets bucket (CloudFront + OAC). Private user uploads stay on AWS_S3_BUCKET.
AWS_S3_PUBLIC_ASSETS_BUCKET="buzzzed-public-assets"
# CloudFront domain for that bucket (no path). Seed joins persona-schema/v1/... under it.
AWS_S3_PUBLIC_ASSETS_BASE_URL="https://d1hjb5dsxfwcg9.cloudfront.net"
# Presigned avatar URL lifetime in seconds (default 1 hour)
AWS_S3_PRESIGNED_URL_EXPIRES_IN="3600"

PORT=3000

# Bootstrap platform admin (run: npm run prisma:seed). Not created via public register.
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="change-me-bootstrap-password"

# Swagger UI (disabled in production): http://localhost:3000/api/docs

# Google Sign-In (frontend sends ID token to POST /auth/google)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
