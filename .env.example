# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_basic?schema=public"

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_ACCESS_EXPIRES_IN="15m"

# Frontend origin(s) for CORS (comma-separated). Required for httpOnly refresh cookie.
CORS_ORIGIN="http://localhost:5173"
REFRESH_TOKEN_COOKIE_NAME="refreshToken"
# COOKIE_SECURE="true"
# COOKIE_SAME_SITE="lax"

# Email verification token lifetime (e.g. 24h, 48h)
EMAIL_VERIFICATION_EXPIRES_IN="24h"

# Frontend URL where users verify email (token appended as ?token=)
APP_VERIFY_EMAIL_URL="http://localhost:3000/verify-email"

# Password reset token lifetime (e.g. 1h, 30m)
PASSWORD_RESET_EXPIRES_IN="1h"

# Frontend URL where users land to set a new password (token appended as ?token=)
APP_RESET_PASSWORD_URL="http://localhost:3000/reset-password"

# AWS (shared by SES and S3)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
SES_FROM_EMAIL="noreply@yourdomain.com"

# S3 profile pictures (private bucket — API returns presigned read URLs)
AWS_S3_BUCKET="your-bucket-name"
AWS_S3_AVATAR_PREFIX="avatars"
# Presigned avatar URL lifetime in seconds (default 1 hour)
AWS_S3_PRESIGNED_URL_EXPIRES_IN="3600"

PORT=3000

# Swagger UI (disabled in production): http://localhost:3000/api/docs
