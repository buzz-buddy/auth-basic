generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum WorkspaceRole {
  OWNER
  MEMBER
  ADMIN
}

enum PersonaStatus {
  DRAFT
  COMPLETE
}

enum ResponseValueSource {
  EMPTY
  USER
  AI
  AI_ACCEPTED
  AI_EDITED
}

enum PersonaFieldType {
  text
  textarea
  single_dropdown
  single_broad_selector
  single_dropdown_with_icon
  multi_radio
  multi_radio_with_brief
  multi_slider
  radio
  file_upload_single
  file_upload_multiple
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  password          String
  role              Role       @default(USER)
  firstName         String?
  lastName          String?
  displayName       String?
  avatarUrl         String?
  dateOfBirth       DateTime?  @db.Date
  status            UserStatus @default(ACTIVE)
  emailVerified     Boolean    @default(false)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  workspaceMemberships    WorkspaceMember[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Workspace {
  id         String   @id @default(cuid())
  name       String?
  websiteUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members   WorkspaceMember[]
  persona   Persona?
  responses WorkspaceQuestionResponse[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(OWNER)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Persona {
  id                           String        @id @default(cuid())
  workspaceId                  String        @unique
  status                       PersonaStatus @default(DRAFT)
  schemaVersion                Int           @default(1)
  currentPersonaSubComponentId Int?
  currentPersonaSubComponent   PersonaSubComponent? @relation(fields: [currentPersonaSubComponentId], references: [id], onDelete: SetNull)
  workspace                    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model PersonaSchemaVersion {
  version     Int      @id
  description String   @default("")
  isActive    Boolean  @default(true)
  publishedAt DateTime @default(now())
}

model PersonaComponent {
  id                   Int                   @id @default(autoincrement())
  slug                 String                @unique
  label                String
  sortOrder            Int
  schemaVersion        Int                   @default(1)
  personaSubComponents PersonaSubComponent[]
}

model PersonaSubComponent {
  id                 Int               @id @default(autoincrement())
  personaComponentId Int
  slug               String
  label              String
  title              String?
  description        String?
  sideInfo           String?           @db.Text
  sortOrder          Int
  personaQuestions   PersonaQuestion[]
  personaComponent   PersonaComponent  @relation(fields: [personaComponentId], references: [id], onDelete: Cascade)
  personasAtLocation Persona[]

  @@unique([personaComponentId, slug])
}

model PersonaQuestion {
  id                    Int                         @id @default(autoincrement())
  personaSubComponentId Int
  fieldType             PersonaFieldType
  name                  String
  label                 String
  isRequired            Boolean                     @default(false)
  fieldConfig           Json?
  isActive              Boolean                     @default(true)
  personaSubComponent   PersonaSubComponent         @relation(fields: [personaSubComponentId], references: [id], onDelete: Cascade)
  responses             WorkspaceQuestionResponse[]

  @@unique([personaSubComponentId, name])
}

model WorkspaceQuestionResponse {
  id                String              @id @default(cuid())
  workspaceId       String
  personaQuestionId Int
  userResponse      Json?
  aiValue           Json?
  valueSource       ResponseValueSource @default(EMPTY)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  personaQuestion PersonaQuestion @relation(fields: [personaQuestionId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, personaQuestionId])
  @@index([workspaceId])
}
