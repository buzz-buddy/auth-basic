# Copy to .env for Docker Compose (dev or prod).
# Compose overrides DATABASE_URL to use the `db` service hostname.
#
# Development:  docker compose -f docker-compose.dev.yml up --build
# Production:    set DOCKER_IMAGE below, then docker compose -f docker-compose.prod.yml up -d
# Prod seed:     npm run docker:prod:seed  (one-off container; needs BOOTSTRAP_ADMIN_* below)

# Required for production (image built by CI/CD and pushed to Docker Hub)
# DOCKER_IMAGE=your-dockerhub-username/auth-basic:latest
# DOCKER_SEED_IMAGE=your-dockerhub-username/auth-basic:seed

# nginx-proxy — read by api container for reverse proxy + Let's Encrypt SSL

DOCKER_IMAGE=automatebuzzz/buzzzed:v0.1
DOCKER_SEED_IMAGE=automatebuzzz/buzzzed:seed

VIRTUAL_HOST=api.buzzzed.co
VIRTUAL_PORT=3000
LETSENCRYPT_HOST=api.buzzzed.co
LETSENCRYPT_EMAIL=farukh.aleem@futuron.co

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auth_basic
POSTGRES_PORT=5432

DATABASE_URL="postgresql://postgres:postgres@db:5432/auth_basic?schema=public"

JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_ACCESS_EXPIRES_IN="15m"
EMAIL_VERIFICATION_EXPIRES_IN="24h"

PORT=3000
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

PASSWORD_RESET_EXPIRES_IN="1h"

REFRESH_TOKEN_COOKIE_NAME="refreshToken"

APP_RESET_PASSWORD_URL="http://localhost:3000/reset-password"
APP_VERIFY_EMAIL_URL="http://localhost:3000/verify-email"

AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
SES_FROM_EMAIL="noreply@yourdomain.com"

AWS_S3_BUCKET="your-bucket-name"
AWS_S3_AVATAR_PREFIX="avatars"
AWS_S3_PRESIGNED_URL_EXPIRES_IN="3600"

BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="change-me-bootstrap-password"

GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
